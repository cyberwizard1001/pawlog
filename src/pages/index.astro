---
/**
 * @module index
 * @description Main UI — server-rendered page tree with Alpine.js for all dynamic behaviour (page selection, editing, history, diff).
 */
import Shell from '../layouts/Shell.astro';
import Modal from '../components/Modal.astro';
---
<Shell>
<div class="app" x-data="pawlog()">

<!-- SIDEBAR OVERLAY (mobile) -->
<div class="sidebar-overlay" x-show="sidebarOpen" @click="sidebarOpen = false"></div>

<!-- SIDEBAR -->
<aside class="sidebar" :class="{ 'sidebar--open': sidebarOpen }">
  <div class="sidebar-header">
    <span class="sidebar-logo">&#x1F43E;</span>
    <span class="sidebar-title">Pawlog</span>
    <div class="sidebar-header-actions">
      <button class="new-page-btn" @click="exportAll()" title="Export all content">&#x2193;</button>
      <label class="new-page-btn" title="Import all content" style="cursor:pointer">
        &#x2191;
        <input type="file" accept=".json" style="display:none" @change="importAll($event.target.files[0]); $event.target.value=''">
      </label>
    </div>
  </div>
  <nav class="sidebar-nav">
    <button
      class="sidebar-nav-btn"
      :class="{ 'sidebar-nav-btn--active': !selectedPath }"
      @click="selectedPath = ''"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Dashboard
    </button>
    <div class="sidebar-section-label">Journeys</div>
    <template x-for="journey in tree" :key="journey.slug">
      <div class="journey-group">
        <div class="journey-row">
          <button
            class="journey-btn"
            @click="journeyOpen[journey.slug] = !journeyOpen[journey.slug]"
            :class="{ 'journey-btn--open': journeyOpen[journey.slug] }"
          >
            <span class="journey-chevron" :class="{ rotated: journeyOpen[journey.slug] }">&#x203A;</span>
            <span x-text="journey.name"></span>
          </button>
          <template x-if="deleteJourneyPending !== journey.slug">
            <div class="journey-actions">
              <button class="new-page-btn" @click.stop="openNewPage(journey.slug)" title="New page">+</button>
              <button class="new-page-btn" @click.stop="openEditJourney(journey)" title="Edit journey">&#x270E;</button>
              <button class="new-page-btn" @click.stop="exportJourney(journey.slug)" title="Export journey as JSON">&#x2193;</button>
              <label class="new-page-btn" title="Import journey from JSON" style="cursor:pointer" @click.stop>
                &#x2191;
                <input type="file" accept=".json" style="display:none" @change="importJourney(journey.slug, $event.target.files[0]); $event.target.value=''">
              </label>
              <button class="new-page-btn" @click.stop="openExportJourney(journey)" title="Export journey to Word"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></button>
              <button class="new-page-btn new-page-btn--danger" @click.stop="deleteJourneyPending = journey.slug" title="Delete journey"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
            </div>
          </template>
          <template x-if="deleteJourneyPending === journey.slug">
            <div class="journey-delete-confirm">
              <button class="journey-delete-yes" @click.stop="deleteJourney()" :disabled="deleteJourneySaving" x-text="deleteJourneySaving ? '…' : 'Del'"></button>
              <button class="journey-delete-no" @click.stop="deleteJourneyPending = ''">&#x2715;</button>
            </div>
          </template>
        </div>
        <div class="page-list" x-show="journeyOpen[journey.slug]" x-transition>
          <template x-for="page in journey.pages" :key="page.path">
            <button
              class="page-btn"
              :class="{ 'page-btn--active': selectedPath === page.path }"
              @click="selectPage(page.path)"
              x-text="page.name"
            ></button>
          </template>
        </div>
      </div>
    </template>
    <div class="sidebar-footer">
      <button class="new-journey-btn" @click="openNewJourney()">+ New journey</button>
    </div>
  </nav>
</aside>

<!-- MAIN CONTENT -->
<main class="main">
  <div class="mobile-topbar">
    <button class="hamburger-btn" @click="sidebarOpen = !sidebarOpen" aria-label="Toggle navigation">
      <span class="hamburger-icon"></span>
      <span class="hamburger-icon"></span>
      <span class="hamburger-icon"></span>
    </button>
    <span class="mobile-title">&#x1F43E; Pawlog</span>
  </div>

  <div class="import-banner import-banner--error" x-show="importError" @click="importError = ''" x-text="importError"></div>
  <div class="import-banner import-banner--loading" x-show="importing">Importing…</div>

  <div x-show="!selectedPath">
    <div class="loading-state" x-show="dashLoading" style="min-height:200px;">
      <div class="spinner"></div>
    </div>
    <div class="dashboard" x-show="!dashLoading && dashboard">
      <h1 class="dashboard-heading">&#x1F43E; Pawlog</h1>
      <p class="dashboard-sub">Pet insurance copy management</p>

      <div class="stat-cards">
        <div class="stat-card">
          <div class="stat-value" x-text="dashboard?.stats?.journeys ?? '—'"></div>
          <div class="stat-label">Journeys</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" x-text="dashboard?.stats?.pages ?? '—'"></div>
          <div class="stat-label">Pages</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" x-text="dashboard?.stats?.items ?? '—'"></div>
          <div class="stat-label">Copy items</div>
        </div>
      </div>

      <div class="section-heading">Recent changes</div>

      <div class="dashboard-empty" x-show="(dashboard?.recent ?? []).length === 0">
        No commits yet.
      </div>

      <div class="recent-list" x-show="(dashboard?.recent ?? []).length > 0">
        <template x-for="commit in (dashboard?.recent ?? [])" :key="commit.hash">
          <div class="recent-entry">
            <div class="recent-top">
              <span class="recent-msg" x-text="commit.message"></span>
              <div class="recent-meta">
                <span class="recent-hash" x-text="commit.hash.substring(0,7)"></span>
                <span class="recent-date" x-text="formatDate(commit.date)"></span>
              </div>
            </div>
            <div class="recent-files">
              <template x-for="file in commit.files" :key="file">
                <template x-if="file.endsWith('.json') && file !== 'journeys.json'">
                  <button
                    class="recent-file-btn"
                    @click="selectPage(file)"
                    x-text="file"
                  ></button>
                </template>
                <template x-if="!file.endsWith('.json') || file === 'journeys.json'">
                  <span class="recent-file-tag" x-text="file"></span>
                </template>
              </template>
            </div>
          </div>
        </template>
      </div>
    </div>
  </div>

  <div class="loading-state" x-show="selectedPath && loading">
    <div class="spinner"></div>
  </div>

  <div class="content-area" x-show="selectedPath && !loading && currentFile">
    <header class="content-header">
      <div>
        <h1 class="page-title" x-text="currentFile?.meta?.page"></h1>
        <p class="page-desc" x-text="currentFile?.meta?.description ?? ''" x-show="currentFile?.meta?.description"></p>
      </div>
      <div class="header-actions">
        <button class="icon-btn" @click="exportPage()" title="Export page JSON">&#x2193;</button>
        <label class="icon-btn" title="Import page JSON" style="cursor:pointer">
          &#x2191;
          <input type="file" accept=".json" style="display:none" @change="importPage($event.target.files[0]); $event.target.value=''">
        </label>
        <button class="icon-btn" @click="openEditPage()" title="Edit page">&#x270E;</button>
        <button class="icon-btn" @click="openExportPage()" title="Export page"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></button>
        <template x-if="!deletePagePending">
          <button class="icon-btn icon-btn--danger" @click="deletePagePending = true" title="Delete page"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
        </template>
        <template x-if="deletePagePending">
          <div class="delete-confirm">
            <span>Delete page?</span>
            <button class="danger-btn" @click="deletePage()" :disabled="deletePageSaving" x-text="deletePageSaving ? 'Deleting…' : 'Yes, delete'"></button>
            <button class="cancel-btn" @click="deletePagePending = false">Cancel</button>
          </div>
        </template>
        <button class="groups-btn" @click="openSections()">+ Sections</button>
      </div>
    </header>

    <div class="brand-filter">
      <button class="brand-pill" :class="{ 'brand-pill--active': brandFilter === 'all' }" @click="brandFilter = 'all'">All brands</button>
      <button class="brand-pill brand-pill--pp" :class="{ 'brand-pill--active': brandFilter === 'perfect_pet' }" @click="brandFilter = 'perfect_pet'">Perfect Pet</button>
      <button class="brand-pill brand-pill--np" :class="{ 'brand-pill--active': brandFilter === 'now_pet' }" @click="brandFilter = 'now_pet'">Now Pet</button>
    </div>

    <table class="copy-table">
      <thead>
        <tr>
          <th>Key</th>
          <th>Label</th>
          <th>Description</th>
          <th>Brand</th>
          <th>Content</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <template x-for="row in flatEntries" :key="row.type === 'header' ? '__h_' + row.name : row.key">
          <tr
            :class="row.type === 'header' ? 'group-header-row' : 'copy-row'"
            @click="row.type === 'row' && openEditor(row.key)"
          >
            <td x-show="row.type === 'header'" colspan="6">
              <div class="group-header-cell">
                <span class="group-header-name" x-text="row.name || 'Ungrouped'"></span>
                <button class="add-key-btn add-key-btn--section" @click.stop="openNewKey(row.name)">+ Add key</button>
              </div>
            </td>
            <td x-show="row.type === 'row'"><code class="key-badge" x-text="row.key ?? ''"></code></td>
            <td x-show="row.type === 'row'" class="label-cell" x-text="row.item?.label ?? ''"></td>
            <td x-show="row.type === 'row'" class="desc-cell" x-text="row.item?.description ?? '—'"></td>
            <td x-show="row.type === 'row'" class="brand-cell">
              <span
                x-show="row.item?.brand === 'perfect_pet'"
                class="brand-badge brand-badge--pp"
              >Perfect Pet</span>
              <span
                x-show="row.item?.brand === 'now_pet'"
                class="brand-badge brand-badge--np"
              >Now Pet</span>
              <span
                x-show="!row.item?.brand"
                class="brand-badge brand-badge--all"
              >All</span>
            </td>
            <td x-show="row.type === 'row'" class="content-cell" x-text="row.item?.content ?? ''"></td>
            <td x-show="row.type === 'row'" class="action-cell">
              <button class="edit-btn" @click.stop="openEditor(row.key)">Edit</button>
            </td>
          </tr>
        </template>
      </tbody>
    </table>
  </div>
</main>

<!-- OVERLAY (slide panel only) -->
<div
  class="overlay"
  x-show="panelOpen"
  @click="panelOpen = false"
  x-transition:enter="overlay-enter"
  x-transition:enter-start="overlay-start"
  x-transition:enter-end="overlay-end"
></div>

<!-- SLIDE-OVER PANEL -->
<aside
  class="panel"
  x-show="panelOpen"
  x-transition:enter="panel-enter"
  x-transition:enter-start="panel-start"
  x-transition:enter-end="panel-end"
  x-transition:leave="panel-enter"
  x-transition:leave-start="panel-end"
  x-transition:leave-end="panel-start"
>
  <div class="panel-header">
    <div>
      <div class="panel-label" x-text="editLabel"></div>
      <code class="panel-key" x-text="editingKey"></code>
    </div>
    <button class="panel-close" @click="panelOpen = false">&#x2715;</button>
  </div>

  <div class="panel-tabs">
    <button class="tab-btn" :class="{ 'tab-btn--active': activeTab === 'edit' }" @click="switchTab('edit')">Edit</button>
    <button class="tab-btn" :class="{ 'tab-btn--active': activeTab === 'history' }" @click="switchTab('history')">History</button>
  </div>

  <div class="panel-body" x-show="activeTab === 'edit'">
    <div>
      <label class="field-label">Content</label>
      <textarea class="content-editor" x-model="editContent" rows="6"></textarea>
    </div>

    <div x-show="(currentFile?.meta?.groups ?? []).length > 0">
      <label class="field-label">Section <span class="optional">(optional)</span></label>
      <select class="note-input" x-model="editGroup">
        <option value="">— None —</option>
        <template x-for="g in (currentFile?.meta?.groups ?? [])" :key="g">
          <option :value="g" x-text="g"></option>
        </template>
      </select>
    </div>

    <div>
      <label class="field-label">Brand <span class="optional">(optional)</span></label>
      <select class="note-input" x-model="editBrand">
        <option value="">All brands</option>
        <option value="perfect_pet">Perfect Pet</option>
        <option value="now_pet">Now Pet</option>
      </select>
    </div>

    <div>
      <label class="field-label">Note <span class="optional">(optional)</span></label>
      <input class="note-input" type="text" x-model="editNote" placeholder="e.g. Q2 rebrand update" />
    </div>

    <div class="panel-actions">
      <button
        class="save-btn"
        @click="saveItem()"
        :disabled="saving"
        x-text="saving ? 'Saving…' : (saveSuccess ? 'Saved ✓' : 'Save')"
        :class="{ 'save-btn--success': saveSuccess }"
      ></button>
      <template x-if="!deleteKeyPending">
        <button class="icon-btn icon-btn--danger" @click="deleteKeyPending = true" title="Delete key"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
      </template>
      <template x-if="deleteKeyPending">
        <div class="delete-confirm">
          <span>Delete this key?</span>
          <button class="danger-btn" @click="deleteKey()" :disabled="deleteKeySaving" x-text="deleteKeySaving ? 'Deleting…' : 'Yes, delete'"></button>
          <button class="cancel-btn" @click="deleteKeyPending = false">Cancel</button>
        </div>
      </template>
    </div>
  </div>

  <div class="panel-body" x-show="activeTab === 'history'">
    <div class="hist-loading" x-show="histLoading">Loading history&#x2026;</div>

    <div x-show="!histLoading && history.length === 0" class="hist-empty">No commits yet for this file.</div>

    <div x-show="!histLoading && history.length > 0">
      <p class="hist-hint" x-show="selectedHashes.length < 2">Select two commits to diff them.</p>
      <button class="diff-btn" x-show="selectedHashes.length === 2" @click="loadDiff()">Show Diff</button>

      <div class="diff-view" x-show="diffLines.length > 0">
        <button class="diff-close" @click="diffLines = []; selectedHashes = []" aria-label="Close diff">&times;</button>
        <template x-for="(line, i) in diffLines" :key="i">
          <div
            class="diff-line"
            :class="{
              'diff-add': line.startsWith('+') && !line.startsWith('+++'),
              'diff-remove': line.startsWith('-') && !line.startsWith('---'),
              'diff-meta': line.startsWith('@@') || line.startsWith('diff') || line.startsWith('index')
            }"
            x-text="line || ' '"
          ></div>
        </template>
      </div>

      <ul class="hist-list">
        <template x-for="(entry, idx) in history" :key="entry.hash">
          <li
            class="hist-entry"
            :class="{ 'hist-entry--selected': selectedHashes.includes(entry.hash) }"
            @click="toggleHashSelect(entry.hash)"
          >
            <div class="hist-top">
              <span class="hist-msg" x-text="entry.message"></span>
              <span class="hist-hash" x-text="entry.hash.substring(0, 7)"></span>
            </div>
            <div class="hist-bottom">
              <span class="hist-date" x-text="formatDate(entry.date)"></span>
              <button
                x-show="idx > 0"
                class="restore-btn"
                :disabled="restoringHash === entry.hash"
                x-text="restoringHash === entry.hash ? 'Restoring…' : 'Use this version'"
                @click.stop="restoreVersion(entry.hash)"
              ></button>
            </div>
          </li>
        </template>
      </ul>
    </div>
  </div>
</aside>

<!-- NEW PAGE MODAL -->
<Modal title="New page" state="newPageOpen">
  <div slot="body">
    <div>
      <label class="field-label">Journey</label>
      <select class="note-input" x-model="newPageJourney">
        <template x-for="j in tree" :key="j.slug">
          <option :value="j.slug" x-text="j.name"></option>
        </template>
      </select>
    </div>
    <div>
      <label class="field-label">Page name</label>
      <input class="note-input" type="text" x-model="newPageName" @input="onPageNameInput()" placeholder="e.g. Homepage" />
    </div>
    <div>
      <label class="field-label">Slug <span class="optional">(filename)</span></label>
      <input class="note-input" type="text" x-model="newPageSlug" placeholder="e.g. homepage" />
    </div>
    <div>
      <label class="field-label">Description <span class="optional">(optional)</span></label>
      <input class="note-input" type="text" x-model="newPageDesc" placeholder="e.g. Main landing page copy" />
    </div>
    <p class="error-msg" x-show="newPageError" x-text="newPageError"></p>
  </div>
  <div slot="footer">
    <button
      class="save-btn"
      @click="createPage()"
      :disabled="newPageSaving || !newPageName || !newPageSlug"
      x-text="newPageSaving ? 'Creating…' : 'Create page'"
    ></button>
  </div>
</Modal>

<!-- NEW KEY MODAL -->
<Modal title="New key" state="newKeyOpen">
  <div slot="body">
    <div>
      <label class="field-label">Key <span class="optional">(snake_case)</span></label>
      <input class="note-input" type="text" x-model="newKeyKey" placeholder="e.g. hero_headline" />
    </div>
    <div>
      <label class="field-label">Label</label>
      <input class="note-input" type="text" x-model="newKeyLabel" placeholder="e.g. Hero Headline" />
    </div>
    <div>
      <label class="field-label">Description <span class="optional">(optional)</span></label>
      <input class="note-input" type="text" x-model="newKeyDesc" placeholder="e.g. Main heading on hero section" />
    </div>
    <div x-show="(currentFile?.meta?.groups ?? []).length > 0">
      <label class="field-label">Section <span class="optional">(optional)</span></label>
      <select class="note-input" x-model="newKeyGroup">
        <option value="">— None —</option>
        <template x-for="g in (currentFile?.meta?.groups ?? [])" :key="g">
          <option :value="g" x-text="g"></option>
        </template>
      </select>
    </div>
    <div>
      <label class="field-label">Brand <span class="optional">(optional)</span></label>
      <select class="note-input" x-model="newKeyBrand">
        <option value="">All brands</option>
        <option value="perfect_pet">Perfect Pet</option>
        <option value="now_pet">Now Pet</option>
      </select>
    </div>
    <div>
      <label class="field-label">Content</label>
      <textarea class="content-editor" x-model="newKeyContent" rows="4" placeholder="Copy text goes here"></textarea>
    </div>
    <p class="error-msg" x-show="newKeyError" x-text="newKeyError"></p>
  </div>
  <div slot="footer">
    <button
      class="save-btn"
      @click="createKey()"
      :disabled="newKeySaving || !newKeyKey || !newKeyLabel"
      x-text="newKeySaving ? 'Adding…' : 'Add key'"
    ></button>
  </div>
</Modal>

<!-- EDIT PAGE MODAL -->
<Modal title="Edit page" state="editPageOpen">
  <div slot="body">
    <div>
      <label class="field-label">Page name</label>
      <input class="note-input" type="text" x-model="editPageName" placeholder="e.g. Homepage" />
    </div>
    <div>
      <label class="field-label">Description <span class="optional">(optional)</span></label>
      <input class="note-input" type="text" x-model="editPageDesc" placeholder="e.g. Main landing page copy" />
    </div>
    <p class="error-msg" x-show="editPageError" x-text="editPageError"></p>
  </div>
  <div slot="footer">
    <button
      class="save-btn"
      @click="savePage()"
      :disabled="editPageSaving || !editPageName"
      x-text="editPageSaving ? 'Saving…' : 'Save changes'"
    ></button>
  </div>
</Modal>

<!-- NEW JOURNEY MODAL -->
<Modal title="New journey" state="newJourneyOpen">
  <div slot="body">
    <div>
      <label class="field-label">Journey name</label>
      <input class="note-input" type="text" x-model="newJourneyName" @input="onJourneyNameInput()" placeholder="e.g. Email" />
    </div>
    <div>
      <label class="field-label">Slug <span class="optional">(folder name)</span></label>
      <input class="note-input" type="text" x-model="newJourneySlug" placeholder="e.g. email" />
    </div>
    <div>
      <label class="field-label">Description <span class="optional">(optional)</span></label>
      <input class="note-input" type="text" x-model="newJourneyDesc" placeholder="e.g. Transactional and marketing emails" />
    </div>
    <p class="error-msg" x-show="newJourneyError" x-text="newJourneyError"></p>
  </div>
  <div slot="footer">
    <button
      class="save-btn"
      @click="createJourney()"
      :disabled="newJourneySaving || !newJourneyName || !newJourneySlug"
      x-text="newJourneySaving ? 'Creating…' : 'Create journey'"
    ></button>
  </div>
</Modal>

<!-- EDIT JOURNEY MODAL -->
<Modal title="Edit journey" state="editJourneyOpen">
  <div slot="body">
    <div>
      <label class="field-label">Journey name</label>
      <input class="note-input" type="text" x-model="editJourneyName" placeholder="e.g. Email" />
    </div>
    <div>
      <label class="field-label">Description <span class="optional">(optional)</span></label>
      <input class="note-input" type="text" x-model="editJourneyDesc" placeholder="e.g. Transactional and marketing emails" />
    </div>
    <p class="error-msg" x-show="editJourneyError" x-text="editJourneyError"></p>
  </div>
  <div slot="footer">
    <button
      class="save-btn"
      @click="saveJourney()"
      :disabled="editJourneySaving || !editJourneyName"
      x-text="editJourneySaving ? 'Saving…' : 'Save changes'"
    ></button>
  </div>
</Modal>

<!-- EXPORT MODAL -->
<Modal title="Export to Word" state="exportOpen">
  <div slot="body">
    <p class="export-scope-label">
      <span x-show="exportMode === 'journey'">Journey: <strong x-text="exportJourneyName"></strong></span>
      <span x-show="exportMode === 'page'">Page: <strong x-text="currentFile?.meta?.page ?? ''"></strong></span>
    </p>
    <div x-show="exportMode === 'page' && exportSections.length > 0">
      <label class="field-label">Section <span class="optional">(optional)</span></label>
      <select class="note-input" x-model="exportSection">
        <option value="">All sections</option>
        <template x-for="s in exportSections" :key="s">
          <option :value="s" x-text="s"></option>
        </template>
      </select>
    </div>
    <div class="export-history-row">
      <label class="export-history-label">
        <input type="checkbox" x-model="exportHistory" class="export-history-check" />
        Include revision history
      </label>
      <span class="optional">Appends git log for each page</span>
    </div>
  </div>
  <div slot="footer">
    <button class="save-btn" @click="doExport()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right:6px;vertical-align:middle"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Download .docx
    </button>
  </div>
</Modal>

<!-- SECTION MANAGEMENT MODAL -->
<Modal title="Manage sections" state="sectionOpen">
  <div slot="body">
    <template x-if="(currentFile?.meta?.groups ?? []).length === 0">
      <p class="hist-empty">No sections yet. Add one below.</p>
    </template>
    <template x-for="(group, index) in (currentFile?.meta?.groups ?? [])" :key="group">
      <div class="section-row">
        <template x-if="sectionEditIndex !== index">
          <span class="section-name" x-text="group"></span>
        </template>
        <template x-if="sectionEditIndex === index">
          <input
            class="note-input section-rename-input"
            type="text"
            x-model="sectionEditName"
            @keydown.enter="renameGroup()"
            @keydown.escape="sectionEditIndex = -1"
          />
        </template>
        <div class="section-actions">
          <template x-if="sectionEditIndex !== index">
            <button class="icon-btn" @click="sectionEditIndex = index; sectionEditName = group" :disabled="sectionSaving" title="Rename">&#x270E;</button>
          </template>
          <template x-if="sectionEditIndex === index">
            <button class="save-btn" style="padding:5px 12px;font-size:12px;" @click="renameGroup()" :disabled="sectionSaving">OK</button>
          </template>
          <button class="icon-btn icon-btn--danger" @click="deleteGroup(group)" :disabled="sectionSaving" title="Delete section"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
        </div>
      </div>
    </template>
    <div class="section-add-row">
      <input
        class="note-input"
        type="text"
        x-model="sectionNewName"
        placeholder="New section name"
        @keydown.enter="addGroup()"
      />
      <button class="add-key-btn" @click="addGroup()" :disabled="sectionSaving || !sectionNewName.trim()">Add</button>
    </div>
  </div>
</Modal>

</div>
</Shell>
